# Keep the Docker build context small and the image clean.
# Anything listed here is NOT sent to the Docker daemon or copied by `COPY . .`.

# The local virtualenv — huge, and Linux-incompatible (built on Windows).
# Dependencies are installed fresh inside the image from requirements.txt.
.venv/

# Python bytecode / caches.
__pycache__/
*.pyc
.pytest_cache/

# Secrets — NEVER bake the real .env into an image. Config is injected at
# runtime (compose env / K8s later). .env.example is fine to include.
.env

# Local DB dumps (already gitignored too).
*.sql
